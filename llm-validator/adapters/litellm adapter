#!/usr/bin/env python3
"""
adapters/litellm_adapter.py; LiteLLM implementation of BaseAdapter.

Supports 100+ providers (OpenAI, Anthropic, Gemini, Ollama, Mistral, etc.)
through a single unified interface via the litellm library.
"""

from typing import Optional

from adapters.base import (
    BaseAdapter,
    CompletionResponse,
    ModelInfo,
    AdapterAuthError,
    AdapterRateLimitError,
    AdapterTimeoutError,
    AdapterContextLengthError,
    AdapterError,
)


class LiteLLMAdapter(BaseAdapter):
    """
    Model-agnostic adapter powered by LiteLLM.

    Any model string LiteLLM supports works here:
        LiteLLMAdapter(model="gpt-4o")
        LiteLLMAdapter(model="claude-sonnet-4-6")
        LiteLLMAdapter(model="ollama/llama3")
        LiteLLMAdapter(model="gemini/gemini-1.5-pro")

    Optional kwargs:
        api_key  (str): Override the default env-var API key.
        api_base (str): Override the provider base URL (e.g. for local endpoints).
    """

    def __init__(self, model: str, timeout: int = 60, **kwargs):
        super().__init__(model=model, timeout=timeout, **kwargs)
        self._api_key: Optional[str] = kwargs.get("api_key")
        self._api_base: Optional[str] = kwargs.get("api_base")

    # ------------------------------------------------------------------
    # Required
    # ------------------------------------------------------------------

    def complete(
        self,
        prompt: str,
        system: Optional[str] = None,
        temperature: float = 1.0,
        max_tokens: Optional[int] = None,
        **kwargs,
    ) -> CompletionResponse:
        try:
            import litellm
        except ImportError:
            raise RuntimeError("litellm is not installed. Run: pip install litellm")

        messages = self._build_messages(prompt, system)

        params = {
            "model": self.model,
            "messages": messages,
            "temperature": temperature,
            "timeout": self.timeout,
            **kwargs,
        }
        if max_tokens is not None:
            params["max_tokens"] = max_tokens
        if self._api_key:
            params["api_key"] = self._api_key
        if self._api_base:
            params["api_base"] = self._api_base

        try:
            raw, latency_ms = self._timed_call(litellm.completion, **params)
        except Exception as e:
            raise self._translate_error(e)

        text = raw.choices[0].message.content or ""
        usage = getattr(raw, "usage", None)

        return CompletionResponse(
            text=text,
            model=getattr(raw, "model", self.model),
            prompt_tokens=getattr(usage, "prompt_tokens", None),
            completion_tokens=getattr(usage, "completion_tokens", None),
            total_tokens=getattr(usage, "total_tokens", None),
            latency_ms=latency_ms,
            raw=raw,
        )

    def model_info(self) -> ModelInfo:
        try:
            import litellm
            info = litellm.get_model_info(self.model) or {}
        except Exception:
            info = {}

        return ModelInfo(
            model=self.model,
            provider=info.get("litellm_provider", "unknown"),
            max_input_tokens=info.get("max_input_tokens"),
            max_output_tokens=info.get("max_output_tokens"),
            supports_system_prompt=True,
            supports_streaming=True,
            supports_functions=info.get("supports_function_calling", False),
            extra=info,
        )

    # ------------------------------------------------------------------
    # Error translation — map litellm exceptions → AdapterError hierarchy
    # ------------------------------------------------------------------

    def _translate_error(self, exc: Exception) -> AdapterError:
        name = type(exc).__name__
        msg = str(exc)

        try:
            import litellm
            if isinstance(exc, litellm.AuthenticationError):
                return AdapterAuthError(msg, provider=self.model.split("/")[0], model=self.model)
            if isinstance(exc, litellm.RateLimitError):
                return AdapterRateLimitError(msg, provider=self.model.split("/")[0], model=self.model)
            if isinstance(exc, litellm.Timeout):
                return AdapterTimeoutError(msg, provider=self.model.split("/")[0], model=self.model)
            if isinstance(exc, litellm.ContextWindowExceededError):
                return AdapterContextLengthError(msg, provider=self.model.split("/")[0], model=self.model)
        except ImportError:
            pass

        return AdapterError(f"{name}: {msg}", model=self.model)
if __name__ == "__main__":
